# Soltard Genesis Parameters
# Source this file before running genesis.sh to customize the chain.
# Changing ANY parameter produces a different genesis hash = unique chain.

# Cluster type: development | devnet | testnet | mainnet-beta
SOLTARD_CLUSTER_TYPE="development"

# Total supply split between bootstrap validator and faucet (in lamports)
# 1 TARD = 1,000,000,000 lamports (same as SOL)
SOLTARD_VALIDATOR_LAMPORTS="500000000000000000"   # 500M TARD
SOLTARD_VALIDATOR_STAKE="1000000000000"            # 1000 TARD stake
SOLTARD_FAUCET_LAMPORTS="500000000000000000"       # 500M TARD

# Epoch and timing
SOLTARD_SLOTS_PER_EPOCH="432000"
SOLTARD_TICKS_PER_SLOT="64"
SOLTARD_HASHES_PER_TICK="auto"

# Genesis archive
SOLTARD_MAX_GENESIS_ARCHIVE="1073741824"  # 1GB
